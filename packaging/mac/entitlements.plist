<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!--
  Mac App Store sandbox entitlements for Pacefinder.

  - app-sandbox: required for MAS submission.
  - network.server: app binds UDP 5300 (Forza telemetry) and TCP 8000 (HTTP dashboard).
  - network.client: needed for outbound Anthropic API calls when AI features are enabled.
  - files.user-selected.read-write: users may override storage_path via the Setup UI.
-->
<plist version="1.0">
<dict>
  <key>com.apple.security.app-sandbox</key>
  <true/>
  <key>com.apple.security.network.server</key>
  <true/>
  <key>com.apple.security.network.client</key>
  <true/>
  <key>com.apple.security.files.user-selected.read-write</key>
  <true/>
</dict>
</plist>
